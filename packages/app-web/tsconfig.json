{
	"include": [
		"**/*", "../core/src/utils/resolved-utils.ts",
	],
	"compilerOptions": {
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": [
			"ESNext",
			"DOM"
		],
		"sourceMap": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"noImplicitReturns": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"vite/client",
			"vite-plugin-pwa/client"
		],
		"paths": {
			"~/*": [
				"./src/*"
			]
		}
	}
}