{
	"include": ["src"],
	"compilerOptions": {
		"rootDir": "./src",
		"noEmit": true,
		"module": "esnext",
		"target": "esnext",
		"types": [],
		"noUncheckedIndexedAccess": true,
		"strict": true,
		"jsx": "react-jsx",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
	}
}